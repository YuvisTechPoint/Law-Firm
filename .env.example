# Copy this file to .env and fill values (do NOT commit .env)
CAL_CLIENT_ID=
CAL_CLIENT_SECRET=
CAL_WEBHOOK_SIGNING_KEY=
CAL_REDIRECT_URI=

# Local dev: set to 1 to enable IMAP polling for inbound admin replies
ENABLE_IMAP=0

# Nodemailer SMTP creds (use app password, do NOT commit)
SMTP_USER=
SMTP_PASS=
